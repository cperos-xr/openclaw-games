<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>The Ashmore Sanatorium — OpenClaw Adventures</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap');

* {
  margin: 0;
  padding: 0;
  box-sizing: border-box;
}

html, body {
  height: 100%;
  background: #000;
  color: #33ff33;
  font-family: 'Press Start 2P', 'Courier New', monospace;
  font-size: 12px;
  line-height: 1.6;
  overflow: hidden;
}

body::after {
  content: '';
  position: fixed;
  inset: 0;
  z-index: 999;
  background: repeating-linear-gradient(
    transparent,
    transparent 2px,
    rgba(0,0,0,0.12) 2px,
    rgba(0,0,0,0.12) 4px
  );
  pointer-events: none;
}

#game-container {
  display: grid;
  grid-template-columns: 1fr 320px;
  grid-template-rows: auto 1fr auto;
  height: 100vh;
  gap: 8px;
  padding: 8px;
}

#header {
  grid-column: 1 / -1;
  text-align: center;
  padding: 8px;
  border-bottom: 1px solid #226622;
}

#art-display {
  grid-row: 2;
  background: #111;
  border: 2px solid #33ff33;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16px;
}

#art-display svg,
#art-display img {
  max-width: 100%;
  max-height: 100%;
  object-fit: contain;
}

#art-display .no-art {
  color: #226622;
  font-size: 14px;
}

#text-panel {
  grid-row: 2;
  display: flex;
  flex-direction: column;
  border: 2px solid #33ff33;
  background: #111;
}

#scene-name {
  background: #000;
  padding: 8px;
  border-bottom: 1px solid #33ff33;
  text-align: center;
  font-size: 14px;
  color: #ffff33;
}

#text-display {
  flex: 1;
  padding: 12px;
  overflow-y: auto;
}

#text-display p {
  margin-bottom: 12px;
}

#text-display .system {
  color: #33bbff;
}

#text-display .success {
  color: #ffff33;
}

#text-display .locked {
  color: #ff3333;
}

#text-display .error {
  color: #ff5555;
}

#command-bar {
  grid-column: 1;
  grid-row: 3;
  display: flex;
  flex-wrap: wrap;
  gap: 8px;
  padding: 8px;
  border-top: 1px solid #226622;
}

.cmd-btn {
  background: #111;
  color: #33ff33;
  border: 1px solid #33ff33;
  padding: 8px 12px;
  font-family: inherit;
  font-size: 10px;
  cursor: pointer;
}

.cmd-btn.active {
  background: #33ff33;
  color: #000;
}

#exits-bar {
  grid-column: 2;
  grid-row: 3;
  display: flex;
  justify-content: space-around;
  align-items: center;
  padding: 8px;
  border-top: 1px solid #226622;
}

.exit-btn {
  background: #111;
  color: #33ff33;
  border: 1px solid #33ff33;
  width: 60px;
  height: 40px;
  font-family: inherit;
  font-size: 10px;
  cursor: pointer;
}

.exit-btn.available {
  background: #226622;
}

.exit-btn:disabled {
  opacity: 0.3;
  cursor: not-allowed;
}

#inventory-bar {
  grid-column: 1 / -1;
  grid-row: 4;
  display: flex;
  align-items: center;
  gap: 8px;
  padding: 8px;
  border-top: 1px solid #226622;
  min-height: 48px;
}

#inv-label {
  color: #ffff33;
  font-size: 10px;
}

#inv-empty {
  color: #226622;
  font-size: 10px;
}

.inv-item {
  background: #111;
  color: #33ff33;
  border: 1px solid #33ff33;
  padding: 6px 10px;
  font-size: 10px;
  cursor: pointer;
}

.inv-item.selected {
  background: #33ff33;
  color: #000;
}

.inv-item.item-new {
  animation: itemGlow 1s ease-in-out 3;
}

/* Animation keyframes */
@keyframes puzzle-solved {
  0% { filter: brightness(1) drop-shadow(0 0 4px #ffff33); }
  50% { filter: brightness(1.8) drop-shadow(0 0 20px #ffff33); }
  100% { filter: brightness(1) drop-shadow(0 0 4px #ffff33); }
}

@keyframes unlockPulse {
  0% { transform: scale(1); }
  50% { transform: scale(1.05); }
  100% { transform: scale(1); }
}

@keyframes itemGlow {
  0% { box-shadow: 0 0 4px #33ff33; }
  50% { box-shadow: 0 0 16px #33ff33; }
  100% { box-shadow: 0 0 4px #33ff33; }
}

.puzzle-solved {
  animation: puzzle-solved 0.6s ease-out;
}

.unlock-pulse {
  animation: unlockPulse 0.6s ease-out;
}

.look-target {
  color: #ffff33;
  text-decoration: underline;
  cursor: pointer;
}

.look-target:hover {
  color: #ffcc00;
}

#footer {
  grid-column: 1 / -1;
  text-align: center;
  padding: 8px;
  color: #113311;
  font-size: 8px;
  border-top: 1px solid #113311;
}
</style>
</head>
<body>
<div id="game-container">
  <div id="header">
    <h1>THE ASHMORE SANATORIUM</h1>
    <div>OpenClaw Adventures — Game #003</div>
  </div>

  <div id="art-display">
    <span class="no-art">[ART LOADING]</span>
  </div>

  <div id="text-panel">
    <div id="scene-name">FOYER</div>
    <div id="text-display"></div>
  </div>

  <div id="command-bar">
    <button class="cmd-btn" data-cmd="look">LOOK</button>
    <button class="cmd-btn" data-cmd="take">TAKE</button>
    <button class="cmd-btn" data-cmd="use">USE</button>
    <button class="cmd-btn" data-cmd="examine">EXAMINE</button>
  </div>

  <div id="exits-bar">
    <button class="exit-btn" data-dir="north">NORTH</button>
    <button class="exit-btn" data-dir="south">SOUTH</button>
    <button class="exit-btn" data-dir="east">EAST</button>
    <button class="exit-btn" data-dir="west">WEST</button>
  </div>

  <div id="inventory-bar">
    <span id="inv-label">INVENTORY:</span>
    <span id="inv-empty">(empty)</span>
  </div>

  <div id="footer">
    OpenClaw Point & Click Studio | Commands: LOOK, TAKE, USE, EXAMINE | Click exits to move | Press / to restart
  </div>
</div>

<script>
// ============================================================
const GAME_DATA = {
  "title": "The Ashmore Sanatorium",
  "slug": "ashmore-sanatorium",
  "number": 3,
  "setting": "A decaying mountain sanatorium from the 1930s, frozen in perpetual winter. Dr. Elara Ashmore conducted experiments merging cryogenic science with consciousness transfer. The building is locked in supernatural cold.",
  "characters": [
    {
      "id": "ashmore",
      "name": "Dr. Elara Ashmore",
