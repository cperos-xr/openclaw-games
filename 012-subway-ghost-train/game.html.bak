<!DOCTYPE html><html><head><meta charset="UTF-8"><meta name="viewport" content="width=device-width, initial-scale=1"><title>Ghost Line | Game #012</title>
<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet"><style>
*{margin:0;padding:0;box-sizing:border-box;}body{background:#000;color:#0f0;font-family:'Press Start 2P',monospace;font-size:12px;line-height:1.4;padding:20px;max-width:1024px;margin:0 auto;display:flex;flex-direction:column;height:100vh;overflow:hidden;}
header{text-align:center;margin-bottom:10px;}h1{font-size:16px;margin-bottom:5px;color:#0f0;text-shadow:0 0 5px #0f0;}h2{font-size:14px;margin-bottom:10px;color:#0f0;}
#scene-name{font-size:18px;text-align:center;margin-bottom:10px;color:#0f0;text-transform:uppercase;letter-spacing:1px;}
.game-container{display:flex;flex:1;gap:20px;min-height:0;}.art-panel{flex:1;border:2px solid #0f0;background:#000;display:flex;justify-content:center;align-items:center;overflow:hidden;min-height:400px;}
#text-display{flex:1;overflow-y:auto;margin-bottom:10px;border-bottom:1px solid #0f0;padding-bottom:10px;}
#text-display p{margin-bottom:10px;color:#0f0;}.system{color:#0a0;font-style:italic;}.success{color:#0f0;font-weight:bold;animation:itemGlow 1s infinite alternate;}.locked{color:#f00;font-weight:bold;}
.command-bar{display:flex;flex-wrap:wrap;gap:10px;margin-bottom:15px;}.cmd-btn{background:#000;color:#0f0;border:1px solid #0f0;padding:5px 10px;font-family:'Press Start 2P',monospace;font-size:10px;cursor:pointer;}
.cmd-btn.active{background:#0f0;color:#000;}.exits-panel{border:2px solid #0f0;background:#000;padding:10px;}
#exits-bar{display:flex;flex-wrap:wrap;gap:8px;}.exit-btn{background:#000;color:#0f0;border:1px solid #0f0;padding:5px 10px;font-family:'Press Start 2P',monospace;font-size:10px;cursor:pointer;}
.look-target{color:#0af;text-decoration:underline;cursor:pointer;}@keyframes itemGlow{0%{text-shadow:0 0 5px #0f0;}100%{text-shadow:0 0 15px #0f0;}}.puzzle-solved{animation:puzzle-solved 0.6s ease-in-out;}
footer{margin-top:20px;text-align:center;font-size:10px;color:#080;}
</style></head><body><header><h1>GHOST LINE</h1><h2>Game #012</h2></header>
<div id="scene-name">STATION PLATFORM</div><div class="game-container"><div class="art-panel"><div id="art-display"></div></div>
<div class="text-panel"><div id="text-display"></div><div class="command-bar"><button class="cmd-btn" data-cmd="look">LOOK</button><button class="cmd-btn" data-cmd="take">TAKE</button><button class="cmd-btn" data-cmd="use">USE</button><button class="cmd-btn" data-cmd="examine">EXAMINE</button></div>
<h3>INVENTORY</h3><div id="inventory-bar"><span id="inv-empty">(empty)</span></div><h3>EXITS</h3><div id="exits-bar"></div></div></div><footer>Use commands or click highlighted words. Click exits to move. Type /restart to reset.</footer>
<script>var GAME_DATA={"title": "Ghost Line", "slug": "subway-ghost-train", "number": 12, "setting": "An abandoned underground subway station where a phantom train still runs on its cursed schedule. The spirits of commuters from a flood disaster forever ride the rails.", "characters": [{"id": "conductor-ghost", "name": "The Conductor", "description": "A spectral figure in a tattered uniform who never stops calling destinations that don't exist."}, {"id": "whisperer", "name": "The Whisperer", "description": "A presence that speaks through the tunnel winds, revealing fragments of the disaster."}], "items": [{"id": "turnstile-key", "name": "Turnstile Key", "description": "A heavy iron key that operates the fare gates.", "foundIn": "station-platform", "usedIn": "station-platform", "usedOn": "locked-turnstile"}, {"id": "lantern", "name": "Lantern", "description": "A battery-powered lantern with a dim but serviceable bulb.", "foundIn": "maintenance-room", "usedIn": "tunnel-north", "usedOn": "collapsed-debris"}, {"id": "maintenance-log", "name": "Maintenance Log", "description": "A water-stained logbook detailing the day of the flood and the train that never returned.", "foundIn": "maintenance-room", "usedIn": "signal-room", "usedOn": "signal-console"}, {"id": "circuit-breaker", "name": "Circuit Breaker", "description": "A replacement breaker for the platform lighting circuit.", "foundIn": "signal-room", "usedIn": "station-platform", "usedOn": "lighting-panel"}, {"id": "brake-handle", "name": "Brake Handle", "description": "The manual release for the ghost train's emergency brake system.", "foundIn": "signal-room", "usedIn": "ghost-train", "usedOn": "brake-mechanism"}], "scenes": [{"id": "station-platform", "name": "Station Platform", "prose": "A cracked and grimy platform stretches into darkness. Flickering\u8367\u5149 signs read 'NO SERVICE'. A turnstile blocks the way onto the platform. Tracks gleam with wetness. Down the tunnel, a faint light pulses.", "exits": {"east": "maintenance-room", "south": "tunnel-north"}, "items": ["turnstile-key"], "puzzles": ["locked-turnstile"], "lookDescriptions": {"turnstile": "A heavy fare gate, locked. You need a key.", "tracks": "The rails are wet and cold. Something heavy recently passed."}}, {"id": "maintenance-room", "name": "Maintenance Room", "prose": "A cramped room filled with tool racks and spare parts. A faded MTA map covers one wall. There's a lantern on a workbench and a logbook soaked with water stains. The door to the signal room is rusty but unlocked.", "exits": {"west": "station-platform", "south": "signal-room"}, "items": ["lantern", "maintenance-log"], "puzzles": [], "lookDescriptions": {"workbench": "Various tools lie scattered. The lantern still works.", "logbook": "Entries describe a flood that trapped a train underground."}}, {"id": "signal-room", "name": "Signal Room", "prose": "Racks of relays and wires fill this room. A signal console glows faintly. A breaker panel hangs open, one slot empty. A heavy brake handle labeled 'GHOST TRAIN' rests on a shelf. The room connects back to the maintenance room and the platform.", "exits": {"north": "maintenance-room", "east": "station-platform"}, "items": ["circuit-breaker", "brake-handle"], "puzzles": ["signal-console", "platform-lights"], "lookDescriptions": {"signal console": "It displays a track map. One line is highlighted: 'Train 7 - Delayed'.", "breaker panel": "Missing a 20-amp breaker. Without it, the platform lights are out."}}, {"id": "tunnel-north", "name": "North Tunnel", "prose": "The tunnel is narrow, walls slick with condensation. Debris blocks the path forward. A faint breeze carries whispers. Your lantern barely cuts through the darkness. The platform is back north.", "exits": {"north": "station-platform"}, "items": [], "puzzles": ["clear-debris"], "lookDescriptions": {"debris": "A collapsed section of ceiling. You could cut through with something.", "whispers": "Voices saying '...next stop... never...'"}}, {"id": "ghost-train", "name": "Ghost Train", "prose": "The train car is transparent, like a hologram. Inside, ghostly commuters sit motionless. The emergency brake system is visible. The train lurches forward as you board. You must release the brake to escape.", "exits": {}, "items": [], "puzzles": ["release-brake"], "lookDescriptions": {"brake mechanism": "A large wheel with a release lever. It needs a manual handle.", "passengers": "Their eyes follow you, pleading."}}, {"id": "escape-platform", "name": "Escape Platform", "prose": "You've cleared the debris, restored power, and boarded the ghost train. By releasing the brake, the train speeds through the phantom tunnels and emerges at an abandoned interchange that leads to the surface. The spirits are at peace. You escape.", "exits": {}, "items": [], "puzzles": [], "lookDescriptions": {"interchange": "A ghostly platform bathed in moonlight. The way out is clear."}}], "puzzles": [{"id": "locked-turnstile", "scene": "station-platform", "requires": ["turnstile-key"], "action": "use turnstile-key on fare gate", "result": "The turnstile clicks and swings open. You can now access the platform area.", "reveals": [], "blocksExit": {"scene": "station-platform", "direction": "south"}, "blockedMessage": "The fare gate is locked. Find a key to proceed."}, {"id": "clear-debris", "scene": "tunnel-north", "requires": ["lantern"], "action": "use lantern to illuminate debris and cut through", "result": "With light, you spot a weak point in the rubble. After effort, the path is clear. You see a ghost train ahead.", "reveals": ["ghost-train"], "blocksExit": {"scene": "tunnel-north", "direction": "south"}, "blockedMessage": "The tunnel is blocked by collapsed rubble. You need a tool to clear it."}, {"id": "signal-console", "scene": "signal-room", "requires": ["maintenance-log"], "action": "use maintenance-log on signal console", "result": "The logbook contains the override codes. The console accepts them and displays: 'TRAIN 7 CLEARED FOR DEPARTURE'. The ghost train becomes accessible.", "reveals": ["ghost-train"], "blocksExit": {}, "blockedMessage": ""}, {"id": "platform-lights", "scene": "signal-room", "requires": ["circuit-breaker"], "action": "install circuit-breaker in panel", "result": "The platform lights flicker on, illuminating the tracks and the train's arrival.", "reveals": [], "blocksExit": {}, "blockedMessage": ""}, {"id": "release-brake", "scene": "ghost-train", "requires": ["brake-handle"], "action": "use brake-handle on emergency mechanism", "result": "You pull the lever. The brake releases. The train accelerates, cycling through tunnels and emerging at an escape platform. YOU WIN.", "reveals": ["escape-platform"], "blocksExit": {}, "blockedMessage": ""}], "winCondition": {"scene": "escape-platform", "requires": [], "description": "You have escaped the subway, freeing both yourself and the commuter ghosts. The phantom train fades into the dawn."}};var GAME_ART={"station-platform": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- platform -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#2a2a3a\"/>\n  <!-- tracks -->\n  <g fill=\"#1a1a2a\">\n    <rect x=\"100\" y=\"270\" width=\"440\" height=\"10\"/>\n    <rect x=\"100\" y=\"300\" width=\"440\" height=\"10\"/>\n  </g>\n  <!-- turnstile -->\n  <g transform=\"translate(50,200)\">\n    <rect x=\"0\" y=\"0\" width=\"60\" height=\"80\" fill=\"#3a3a4a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <rect x=\"10\" y=\"20\" width=\"40\" height=\"40\" fill=\"#0f0\"/>\n  </g>\n  <!-- tunnel entrance south -->\n  <rect x=\"300\" y=\"150\" width=\"120\" height=\"100\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"360\" y=\"195\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">TUNNEL</text>\n  <!-- flickering sign -->\n  <g transform=\"translate(500,80)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"30\" fill=\"#000\" stroke=\"#f00\" stroke-width=\"2\"/>\n    <text x=\"40\" y=\"18\" font-family=\"monospace\" font-size=\"8\" fill=\"#f00\" text-anchor=\"middle\">NO SERVICE</text>\n  </g>\n</svg>", "maintenance-room": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"250\" fill=\"#1a1a2a\"/>\n  <!-- floor -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- tool racks -->\n  <g fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\">\n    <rect x=\"50\" y=\"150\" width=\"120\" height=\"80\"/>\n    <rect x=\"200\" y=\"150\" width=\"120\" height=\"80\"/>\n  </g>\n  <!-- workbench with lantern -->\n  <rect x=\"400\" y=\"180\" width=\"150\" height=\"50\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n  <!-- lantern on bench -->\n  <g transform=\"translate(420,190)\">\n    <rect x=\"0\" y=\"0\" width=\"20\" height=\"30\" fill=\"#4a4a5a\" stroke=\"#0f0\" stroke-width=\"1\"/>\n    <circle cx=\"10\" cy=\"10\" r=\"8\" fill=\"#0f0\"/>\n  </g>\n  <!-- logbook on bench -->\n  <g transform=\"translate(480,200)\">\n    <rect x=\"0\" y=\"0\" width=\"40\" height=\"30\" fill=\"#5a3a1a\" stroke=\"#ffd700\" stroke-width=\"1\"/>\n  </g>\n  <!-- exit west to platform -->\n  <rect x=\"100\" y=\"320\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"140\" y=\"352\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n  <!-- exit south to signal -->\n  <rect x=\"300\" y=\"340\" width=\"80\" height=\"40\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"340\" y=\"372\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">SIGNAL</text>\n</svg>", "signal-room": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"250\" fill=\"#1a1a2a\"/>\n  <!-- floor -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- relay racks -->\n  <g fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\">\n    <rect x=\"50\" y=\"100\" width=\"150\" height=\"120\"/>\n    <rect x=\"450\" y=\"100\" width=\"150\" height=\"120\"/>\n  </g>\n  <!-- signal console -->\n  <g transform=\"translate(260,120)\">\n    <rect x=\"0\" y=\"0\" width=\"120\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <rect x=\"10\" y=\"20\" width=\"100\" height=\"20\" fill=\"#0f0\"/>\n    <text x=\"60\" y=\"32\" font-family=\"monospace\" font-size=\"8\" fill=\"#000\" text-anchor=\"middle\">TRAIN 7</text>\n  </g>\n  <!-- breaker panel -->\n  <g transform=\"translate(500,250)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"50\" fill=\"#2a2a3a\" stroke=\"#f00\" stroke-width=\"2\"/>\n    <rect x=\"10\" y=\"15\" width=\"20\" height=\"20\" fill=\"#f00\"/>\n    <text x=\"40\" y=\"28\" font-family=\"monospace\" font-size=\"8\" fill=\"#f00\" text-anchor=\"middle\">EMPTY</text>\n  </g>\n  <!-- brake handle on shelf -->\n  <g transform=\"translate(100,200)\">\n    <rect x=\"0\" y=\"0\" width=\"60\" height=\"30\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n    <circle cx=\"30\" cy=\"15\" r=\"8\" fill=\"#ff4500\"/>\n  </g>\n  <!-- exits -->\n  <rect x=\"200\" y=\"330\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"240\" y=\"362\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n  <rect x=\"300\" y=\"80\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"340\" y=\"112\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">MAINT</text>\n</svg>", "tunnel-north": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- tunnel walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"150\" fill=\"#1a1a2a\"/>\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- arched ceiling -->\n  <path d=\"M0,150 Q320,100 640,150\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <!-- debris pile -->\n  <g transform=\"translate(300,200)\">\n    <rect x=\"0\" y=\"0\" width=\"100\" height=\"60\" fill=\"#3a3a4a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n    <polygon points=\"20,0 80,0 50,-20\" fill=\"#2a2a3a\"/>\n  </g>\n  <!-- light from ghost train ahead -->\n  <circle cx=\"320\" cy=\"180\" r=\"20\" fill=\"#fff\" opacity=\"0.5\"/>\n  <!-- whispers -->\n  <g font-family=\"monospace\" font-size=\"8\" fill=\"#aaa\">\n    <text x=\"100\" y=\"120\">...next stop...</text>\n    <text x=\"400\" y=\"140\">...never...</text>\n  </g>\n  <!-- exit north to platform -->\n  <rect x=\"280\" y=\"30\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"320\" y=\"62\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n</svg>", "ghost-train": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- train car outline -->\n  <ellipse cx=\"320\" cy=\"200\" rx=\"200\" ry=\"80\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <!-- ghostly passengers -->\n  <g fill=\"#666\" opacity=\"0.6\">\n    <ellipse cx=\"260\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n    <ellipse cx=\"320\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n    <ellipse cx=\"380\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n  </g>\n  <!-- emergency brake mechanism -->\n  <g transform=\"translate(280,250)\">\n    <circle cx=\"20\" cy=\"20\" r=\"30\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <line x1=\"20\" y1=\"20\" x2=\"20\" y2=\"50\" stroke=\"#888\" stroke-width=\"4\"/>\n    <circle cx=\"20\" cy=\"20\" r=\"8\" fill=\"#f00\"/>\n  </g>\n  <!-- train control panel -->\n  <g transform=\"translate(450,200)\">\n    <rect x=\"0\" y=\"0\" width=\"60\" height=\"40\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n    <text x=\"30\" y=\"20\" font-family=\"monospace\" font-size=\"8\" fill=\"#0f0\" text-anchor=\"middle\">BRAKE</text>\n  </g>\n</svg>", "escape-platform": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- moonlit platform -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#2a2a3a\"/>\n  <!-- moonlight shaft -->\n  <rect x=\"200\" y=\"0\" width=\"240\" height=\"250\" fill=\"#e0e0ff\" opacity=\"0.1\"/>\n  <!-- exit signs -->\n  <g transform=\"translate(100,100)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"40\" fill=\"#000\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <text x=\"40\" y=\"22\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">EXIT</text>\n  </g>\n  <g transform=\"translate(460,100)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"40\" fill=\"#000\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <text x=\"40\" y=\"22\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">EXIT</text>\n  </g>\n  <!-- ghostly train fading -->\n  <ellipse cx=\"320\" cy=\"180\" rx=\"150\" ry=\"60\" fill=\"none\" stroke=\"#666\" stroke-width=\"2\" stroke-dasharray=\"10,5\" opacity=\"0.5\"/>\n</svg>", "turnstile-key": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\">\n  <rect width=\"64\" height=\"64\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"10\" y=\"20\" width=\"30\" height=\"20\" fill=\"#6a5acd\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <circle cx=\"40\" cy=\"30\" r=\"5\" fill=\"#6a5acd\" stroke=\"#0f0\" stroke-width=\"2\"/>\n</svg>", "lantern": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\">\n  <rect width=\"64\" height=\"64\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"20\" y=\"10\" width=\"24\" height=\"44\" fill=\"#4a4a5a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"27\" y=\"20\" width=\"10\" height=\"15\" fill=\"#0f0\"/>\n  <circle cx=\"32\" cy=\"40\" r=\"6\" fill=\"#ff0\"/>\n</svg>", "maintenance-log": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\">\n  <rect width=\"64\" height=\"64\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"15\" y=\"10\" width=\"34\" height=\"44\" fill=\"#5a3a1a\" stroke=\"#ffd700\" stroke-width=\"2\"/>\n  <line x1=\"20\" y1=\"20\" x2=\"44\" y2=\"20\" stroke=\"#ffd700\" stroke-width=\"1\"/>\n  <line x1=\"20\" y1=\"26\" x2=\"44\" y2=\"26\" stroke=\"#ffd700\" stroke-width=\"1\"/>\n  <line x1=\"20\" y1=\"32\" x2=\"44\" y2=\"32\" stroke=\"#ffd700\" stroke-width=\"1\"/>\n</svg>", "circuit-breaker": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\">\n  <rect width=\"64\" height=\"64\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"20\" y=\"20\" width=\"24\" height=\"24\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <rect x=\"26\" y=\"26\" width=\"12\" height=\"12\" fill=\"#f00\"/>\n  <text x=\"32\" y=\"45\" font-family=\"monospace\" font-size=\"6\" fill=\"#0f0\" text-anchor=\"middle\">20A</text>\n</svg>", "brake-handle": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 64 64\">\n  <rect width=\"64\" height=\"64\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"2\"/>\n  <g fill=\"#ff4500\" stroke=\"#0f0\" stroke-width=\"2\">\n    <ellipse cx=\"32\" cy=\"32\" rx=\"12\" ry=\"8\"/>\n    <rect x=\"24\" y=\"30\" width=\"16\" height=\"4\"/>\n    <circle cx=\"32\" cy=\"28\" r=\"5\"/>\n  </g>\n</svg>"};// ============================================================
// STARLIGHT DERELICT - GAME LOGIC
// Produced by Gameplay Coder (Hex Corbin)
// ============================================================

// Game data will be embedded by the Game Assembler
var GAME_DATA = {}; // Replace with actual game-script.json contents

// ---- Game State ----
const state = {
  currentScene: 'airlock',
  inventory: [],
  solvedPuzzles: [],
  visitedScenes: ['airlock'],
  activeCommand: null,
  selectedItem: null,
  won: false
};

// ---- DOM References ----
const artDisplay = document.getElementById('art-display');
const sceneName = document.getElementById('scene-name');
const textDisplay = document.getElementById('text-display');
const invBar = document.getElementById('inventory-bar');
const exitsBar = document.getElementById('exits-bar');

// ---- Display Functions ----
function addText(text, cls = '') {
  const p = document.createElement('p');
  p.className = cls;
  p.innerHTML = text;
  textDisplay.appendChild(p);
  textDisplay.scrollTop = textDisplay.scrollHeight;
}

function clearText() { textDisplay.innerHTML = ''; }

function renderScene(sceneId) {
  const scene = GAME_DATA.scenes.find(s => s.id === sceneId);
  if (!scene) { addText('ERROR: Scene not found!', 'error'); return; }

  state.currentScene = sceneId;
  if (!state.visitedScenes.includes(sceneId)) state.visitedScenes.push(sceneId);

  // Update scene name
  sceneName.textContent = scene.name.toUpperCASE();

  // Update art
  const artKey = 'scene-' + sceneId.replace('scene-', '');
  let artHtml = null;
  if (typeof GAME_ART !== 'undefined' && GAME_ART[artKey]) {
    artHtml = GAME_ART[artKey];
  } else if (window.GAME_ART && window.GAME_ART[artKey]) {
    artHtml = window.GAME_ART[artKey];
  } else if (typeof GAME_ART !== 'undefined' && GAME_ART[sceneId]) {
    artHtml = GAME_ART[sceneId];
  } else if (window.GAME_ART && window.GAME_ART[sceneId]) {
    artHtml = window.GAME_ART[sceneId];
  }

  if (artHtml) {
    artDisplay.innerHTML = artHtml;
  } else {
    artDisplay.innerHTML = '<span class="no-art">[ ' + scene.name.toUpperCase() + ' ]</span>';
  }

  // Display prose
  clearText();
  addText(scene.prose);

  // Show available items (not yet taken)
  const availableItems = (scene.items || []).filter(itemId =>
    !state.inventory.includes(itemId)
  );
  if (availableItems.length > 0) {
    const itemNames = availableItems.map(id => {
      const item = GAME_DATA.items.find(i => i.id === id);
      return item ? `<span class="look-target" data-look="${id}">${item.name}</span>` : id;
    });
    addText('You notice: ' + itemNames.join(', '), 'system');
  }

  // Show unsolved puzzles
  const scenePuzzles = (scene.puzzles || []).filter(pid =>
    !state.solvedPuzzles.includes(pid)
  );
  scenePuzzles.forEach(pid => {
    const puzzle = GAME_DATA.puzzles.find(p => p.id === pid);
    if (puzzle) {
      addText('There is something here that catches your attention...', 'system');
    }
  });

  // Render exits
  renderExits(scene.exits || {});

  // Render inventory
  renderInventory();

  // Check win condition
  checkWin();

  // Save state
  saveState();
}

function canExit(sceneId, direction) {
  const exit = GAME_DATA.scenes.find(s => s.id === sceneId)?.exits?.[direction];
  if (!exit) return false;
  
  // Check if any unsolved puzzle blocks this exit
  const blocker = GAME_DATA.puzzles.find(p =>
    p.blocksExit?.scene === sceneId &&
    p.blocksExit?.direction === direction &&
    !state.solvedPuzzles.includes(p.id)
  );
  
  if (blocker) {
    addText(`[The way ${direction} is blocked. ${blocker.blockedMessage || 'Something prevents you from going that way.'}]`, 'locked');
    return false;
  }
  
  return true;
}

function renderExits(exits) {
  exitsBar.innerHTML = '';
  const directions = ['north', 'south', 'east', 'west'];
  directions.forEach(dir => {
    const btn = document.createElement('button');
    btn.className = 'exit-btn' + (exits[dir] ? ' available' : '');
    btn.textContent = dir.toUpperCase();
    btn.disabled = !exits[dir];
    if (exits[dir] && canExit(state.currentScene, dir)) {
      btn.onclick = () => go(exits[dir]);
    }
    exitsBar.appendChild(btn);
  });
}

function renderInventory() {
  const items = invBar.querySelectorAll('.inv-item');
  items.forEach(el => el.remove());
  const empty = document.getElementById('inv-empty');

  if (state.inventory.length === 0) {
    empty.style.display = '';
  } else {
    empty.style.display = 'none';
    state.inventory.forEach(itemId => {
      const item = GAME_DATA.items.find(i => i.id === itemId);
      if (!item) return;
      const el = document.createElement('span');
      el.className = 'inv-item' + (state.selectedItem === itemId ? ' selected' : '');
      el.textContent = item.name;
      el.onclick = () => selectItem(itemId);
      invBar.appendChild(el);
    });
  }
}

// ---- Command Handlers ----
function setCommand(cmd) {
  state.activeCommand = cmd;
  document.querySelectorAll('.cmd-btn').forEach(b => {
    b.classList.toggle('active', b.dataset.cmd === cmd);
  });
  if (cmd === 'look') {
    const scene = GAME_DATA.scenes.find(s => s.id === state.currentScene);
    if (scene && scene.lookDescriptions) {
      const targets = Object.keys(scene.lookDescriptions);
      if (targets.length > 0) {
        addText('You can examine: ' + targets.map(t =>
          `<span class="look-target" data-look="${t}">${t}</span>`
        ).join(', '), 'system');
      }
    }
  } else if (cmd === 'use') {
    if (state.inventory.length > 0) {
      addText('Select an item from your inventory, then click what to use it on.', 'system');
    } else {
      addText('You have nothing to use.', 'system');
    }
  } else if (cmd === 'take') {
    const scene = GAME_DATA.scenes.find(s => s.id === state.currentScene);
    const available = (scene.items || []).filter(id => !state.inventory.includes(id));
    if (available.length > 0) {
      available.forEach(id => takeItem(id));
    } else {
      addText('Nothing here to take.', 'system');
    }
  }
}

function selectItem(itemId) {
  state.selectedItem = state.selectedItem === itemId ? null : itemId;
  renderInventory();
  if (state.selectedItem) {
    const item = GAME_DATA.items.find(i => i.id === itemId);
    addText(`Selected: ${item.name}. Click USE, then a target.`, 'system');
  }
}

function takeItem(itemId) {
  if (state.inventory.includes(itemId)) return;
  const item = GAME_DATA.items.find(i => i.id === itemId);
  if (!item) return;
  const scene = GAME_DATA.scenes.find(s => s.id === state.currentScene);
  if (!scene || !(scene.items || []).includes(itemId)) return;

  state.inventory.push(itemId);
  addText(`You picked up: ${item.name} — ${item.description}`, 'success');
  renderInventory();
  saveState();
  
  // Apply item glow effect for newly acquired items
  setTimeout(() => {
    const itemElements = invBar.querySelectorAll('.inv-item');
    itemElements.forEach(el => {
      if (el.textContent === item.name) {
        el.classList.add('item-new');
        setTimeout(() => el.classList.remove('item-new'), 2000);
      }
    });
  }, 100);
}

function lookAt(target) {
  const scene = GAME_DATA.scenes.find(s => s.id === state.currentScene);
  if (scene && scene.lookDescriptions && scene.lookDescriptions[target]) {
    addText(scene.lookDescriptions[target]);
  } else {
    // Check if it's an item
    const item = GAME_DATA.items.find(i => i.id === target);
    if (item) {
      addText(item.description);
    } else {
      addText('Nothing interesting about that.', 'system');
    }
  }
}

function useItemOn(itemId, targetId) {
  const puzzle = GAME_DATA.puzzles.find(p =>
    p.scene === state.currentScene &&
    p.requires.includes(itemId) &&
    p.id === targetId &&
    !state.solvedPuzzles.includes(p.id)
  );

  if (puzzle && puzzle.requires.every(req => state.inventory.includes(req))) {
    state.solvedPuzzles.push(puzzle.id);
    addText(puzzle.result, 'success');
    
    // Apply puzzle solved flash effect
    artDisplay.classList.add('puzzle-solved');
    setTimeout(() => artDisplay.classList.remove('puzzle-solved'), 600);
    
    // Reveal items or unlock scenes
    (puzzle.reveals || []).forEach(revealId => {
      const revealItem = GAME_DATA.items.find(i => i.id === revealId);
      if (revealItem) {
        state.inventory.push(revealId);
        addText(`You found: ${revealItem.name}!`, 'success');
        
        // Apply item glow for newly revealed items
        setTimeout(() => {
          const itemElements = invBar.querySelectorAll('.inv-item');
          itemElements.forEach(el => {
            if (el.textContent === revealItem.name) {
              el.classList.add('item-new');
              setTimeout(() => el.classList.remove('item-new'), 2000);
            }
          });
        }, 100);
      }
    });
    
    renderInventory();
    
    // Update exit buttons for newly unlocked exits
    const exitButtons = exitsBar.querySelectorAll('.exit-btn');
    exitButtons.forEach(btn => {
      if (btn.classList.contains('available')) {
        btn.classList.add('newly-unlocked');
        setTimeout(() => btn.classList.remove('newly-unlocked'), 3000);
      }
    });
    
    checkWin();
    saveState();
  } else {
    addText("That doesn't seem to work.", 'system');
  }
}

function go(sceneId) {
  if (!canExit(state.currentScene, getDirectionToScene(sceneId))) {
    return; // canExit already shows the message
  }
  addText('---', 'system');
  renderScene(sceneId);
}

function getDirectionToScene(targetSceneId) {
  const currentScene = GAME_DATA.scenes.find(s => s.id === state.currentScene);
  if (!currentScene || !currentScene.exits) return null;
  
  for (const [direction, sceneId] of Object.entries(currentScene.exits)) {
    if (sceneId === targetSceneId) {
      return direction;
    }
  }
  return null;
}

function checkWin() {
  if (state.won) return;
  const wc = GAME_DATA.winCondition;
  if (!wc) return;
  if (state.currentScene === wc.scene &&
      wc.requires.every(req => state.inventory.includes(req))) {
    state.won = true;
    addText('', '');
    addText('*** ' + wc.description + ' ***', 'success');
    addText('', '');
    addText('CONGRATULATIONS! YOU HAVE COMPLETED THE GAME!', 'success');
    addText('Type /restart to play again.', 'system');
  }
}

// ---- Persistence ----
function saveState() {
  try {
    localStorage.setItem('game-' + GAME_DATA.slug, JSON.stringify(state));
  } catch(e) {}
}

function loadState() {
  try {
    const saved = localStorage.getItem('game-' + GAME_DATA.slug);
    if (saved) {
      const s = JSON.parse(saved);
      Object.assign(state, s);
      return true;
    }
  } catch(e) {}
  return false;
}

// ---- Event Listeners ----
document.querySelectorAll('.cmd-btn').forEach(btn => {
  btn.onclick = () => setCommand(btn.dataset.cmd);
});

document.addEventListener('click', (e) => {
  if (e.target.classList.contains('look-target')) {
    const target = e.target.dataset.look;
    if (state.activeCommand === 'use' && state.selectedItem) {
      useItemOn(state.selectedItem, target);
    } else {
      lookAt(target);
    }
  }
});

// ---- Initialize ----
function init() {
  if (Object.keys(GAME_DATA).length === 0) {
    addText('ERROR: No game data loaded. This is a template file.', 'error');
    addText('The Gameplay Coder will embed game data here.', 'system');
    return;
  }

  addText('=== ' + GAME_DATA.title.toUpperCase() + ' ===', 'success');
  addText(GAME_DATA.setting, 'system');
  addText('', '');
  addText('Commands: LOOK | TAKE | USE | EXAMINE', 'system');
  addText('Click exits to move between rooms.', 'system');
  addText('---', 'system');

  if (!loadState()) {
    renderScene('airlock');
  } else {
    renderScene(state.currentScene);
    addText('[Game restored from save]', 'system');
  }
}

init();
document.getElementById("reset-btn")?.addEventListener("click", function() {
    if (confirm("Reset the game to the beginning?")) {
        state = {currentScene: GAME_DATA.scenes[0].id, inventory: [], solvedPuzzles: [], visitedScenes: [GAME_DATA.scenes[0].id], selectedItem: null, won: false};
        clearText(); addText("The story begins anew...", "system");
        renderScene(state.currentScene); renderInventory();
    }
});
    </script></body></html>