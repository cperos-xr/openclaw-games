<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Ghost Line | Game #012</title>
    <link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&display=swap" rel="stylesheet">
    <style>
        /* ============================================================
         * OPENCLAW GAME TEMPLATE v3.0 — MOBILE-FIRST
         *
         * ARCHITECTURE:
         *   Mobile (<769px): Scrollable page. Art top. Content below.
         *   Desktop (≥769px): Fixed 100vh. Art left 60%. Text right 40%.
         *
         * FIVE RULES THAT MUST NEVER BE BROKEN:
         *   1. NEVER add height:100vh + overflow:hidden outside the desktop media query
         *   2. NEVER set min-height > 0px on .art-panel at base/mobile level
         *   3. ALWAYS use aspect-ratio: 8/5 (640x400) for the art panel on mobile
         *   4. ALWAYS use min-height:44px on every clickable button (touch targets)
         *   5. ALWAYS use flex-wrap:wrap on .command-bar and #exits-bar
         * ============================================================ */

        * { margin: 0; padding: 0; box-sizing: border-box; }

        /* CRT scanline overlay */
        body::after {
            content: ''; position: fixed; inset: 0; z-index: 999; pointer-events: none;
            background: repeating-linear-gradient(
                transparent, transparent 2px,
                rgba(0,0,0,0.10) 2px, rgba(0,0,0,0.10) 4px
            );
        }

        /* ── MOBILE BASE (default, all screens) ─────────────────────
         * Normal document flow. No height:100vh. No overflow:hidden.
         * Everything stacks vertically and scrolls naturally.
         * ──────────────────────────────────────────────────────────── */
        body {
            background: #000; color: #33ff33;
            font-family: 'Press Start 2P', 'Courier New', monospace;
            font-size: 11px; line-height: 1.6;
            padding: 8px; max-width: 1200px; margin: 0 auto;
            overflow-x: hidden; /* prevent horizontal scroll from oversized art */
        }

        header { text-align: center; padding-bottom: 8px; }
        h1 { font-size: 13px; color: #33ff33; text-shadow: 0 0 8px #33ff33; margin-bottom: 4px; }
        .subtitle { font-size: 8px; color: #226622; }

        #scene-name {
            font-size: 12px; text-align: center; color: #ffff33;
            text-transform: uppercase; letter-spacing: 1px; padding: 6px 0;
        }

        /* Art panel: fills width, keeps 8:5 (640×400) aspect ratio.
         * max-height: 56vw = ~210px on a 375px phone — art is clear but
         * leaves plenty of room below for text and controls. */
        .art-panel {
            width: 100%; aspect-ratio: 8 / 5; max-height: 56vw;
            border: 2px solid #33ff33; background: #111;
            display: flex; align-items: center; justify-content: center;
            overflow: hidden;
        }
        #art-display { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
        #art-display svg, #art-display img { max-width: 100%; max-height: 100%; object-fit: contain; display: block; }
        .no-art { color: #226622; font-size: 9px; text-align: center; }

        /* Text panel: plain block on mobile, no fixed height */
        .text-panel {
            border: 2px solid #33ff33; background: #111;
            padding: 10px; margin-top: 8px;
        }

        /* Story text: scrollable, capped so it doesn't swallow the whole screen */
        #text-display {
            overflow-y: auto; max-height: 40vh;
            border-bottom: 1px solid #226622; padding-bottom: 8px; margin-bottom: 8px;
        }
        #text-display p { margin-bottom: 8px; }
        #text-display .system  { color: #33bbff; font-style: italic; }
        #text-display .success { color: #ffff33; font-weight: bold; }
        #text-display .locked  { color: #ff3333; }
        #text-display .error   { color: #ff5555; }
        .look-target { color: #ffff33; text-decoration: underline; cursor: pointer; }
        .look-target:hover { color: #ffcc00; }

        /* Command buttons: wrapping row, 44px tap targets */
        .command-bar { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 8px; }
        .cmd-btn {
            background: #000; color: #33ff33; border: 1px solid #33ff33;
            padding: 10px 14px; min-height: 44px; min-width: 44px; flex: 1;
            font-family: 'Press Start 2P', monospace; font-size: 9px; cursor: pointer;
        }
        .cmd-btn:hover, .cmd-btn.active { background: #33ff33; color: #000; }
        #hint-toggle { flex: 0 0 auto; }

        /* Inventory */
        .inventory-panel { border: 1px solid #226622; background: #000; padding: 8px; margin-bottom: 8px; }
        .inventory-panel h3 { font-size: 8px; color: #ffff33; margin-bottom: 6px; }
        #inventory-bar { display: flex; flex-wrap: wrap; gap: 6px; min-height: 18px; }
        #inv-empty { color: #226622; font-size: 9px; }
        .inv-item {
            border: 1px solid #33ff33; padding: 8px 10px; min-height: 36px;
            font-family: inherit; font-size: 9px; cursor: pointer; background: #000; color: #33ff33;
        }
        .inv-item:hover, .inv-item.selected { background: #33ff33; color: #000; }

        /* Exits */
        .exits-panel { border: 1px solid #226622; background: #000; padding: 8px; }
        .exits-panel h3 { font-size: 8px; color: #ffff33; margin-bottom: 6px; }
        #exits-bar { display: flex; flex-wrap: wrap; gap: 6px; }
        .exit-btn {
            background: #000; color: #33ff33; border: 1px solid #33ff33;
            padding: 10px 14px; min-height: 44px; min-width: 44px;
            font-family: 'Press Start 2P', monospace; font-size: 9px; cursor: pointer;
        }
        .exit-btn.available:hover { background: #33ff33; color: #000; }
        .exit-btn:disabled { opacity: 0.3; cursor: not-allowed; }

        .hint { color: #FFAA00 !important; font-style: italic; border-left: 2px solid #FFAA00; padding-left: 8px; margin: 5px 0; }
        .hint::before { content: "HINT: "; font-weight: bold; }

        footer { margin-top: 8px; text-align: center; font-size: 7px; color: #113311; padding: 8px 0; }

        /* Animations */
        @keyframes puzzle-solved {
            0%   { filter: brightness(1) drop-shadow(0 0 4px #ffff33); }
            50%  { filter: brightness(1.8) drop-shadow(0 0 20px #ffff33); }
            100% { filter: brightness(1) drop-shadow(0 0 4px #ffff33); }
        }
        @keyframes itemGlow {
            0%   { box-shadow: 0 0 4px #33ff33; }
            50%  { box-shadow: 0 0 16px #33ff33; }
            100% { box-shadow: 0 0 4px #33ff33; }
        }
        @keyframes unlockPulse {
            0%, 100% { border-color: #33ff33; }
            50% { border-color: #ffff33; box-shadow: 0 0 12px #ffff33; }
        }
        .puzzle-solved { animation: puzzle-solved 0.6s ease-out; }
        .item-new { animation: itemGlow 1s ease-in-out 3; }
        .newly-unlocked { animation: unlockPulse 1s ease 3; }

        /* ── DESKTOP (≥769px): side-by-side, fits 100vh ─────────────
         * Only here do we apply height:100vh + overflow:hidden.
         * Flex layout with min-height:0 so panels can shrink properly.
         * ──────────────────────────────────────────────────────────── */
        @media (min-width: 769px) {
            body {
                display: flex; flex-direction: column;
                height: 100vh; overflow: hidden;
                font-size: 12px; padding: 12px;
            }
            header { flex-shrink: 0; margin-bottom: 6px; }
            h1 { font-size: 16px; }
            .subtitle { font-size: 9px; }
            #scene-name { font-size: 14px; letter-spacing: 2px; margin-bottom: 8px; flex-shrink: 0; }

            .game-container {
                display: flex; flex: 1; gap: 12px;
                min-height: 0; /* CRITICAL: lets flex children shrink below content height */
            }
            .art-panel {
                flex: 3; aspect-ratio: unset; max-height: none; /* flex dictates height */
                margin-top: 0;
            }
            .text-panel {
                flex: 2; display: flex; flex-direction: column;
                overflow: hidden; margin-top: 0;
            }
            #text-display { flex: 1; max-height: none; overflow-y: auto; }
            .cmd-btn    { flex: 1; padding: 6px 10px; min-height: 36px; }
            .exit-btn   { padding: 6px 10px; min-height: 36px; }
            .inv-item   { padding: 4px 8px; min-height: 30px; }
            footer { flex-shrink: 0; }
        }

        /* ── LANDSCAPE MOBILE (short + wide) ───────────────────────── */
        @media (max-height: 500px) and (orientation: landscape) {
            .game-container { display: flex !important; flex-direction: row !important; }
            .art-panel { flex: 1; aspect-ratio: unset; max-height: none; }
            .text-panel { flex: 1; overflow-y: auto; }
            #text-display { max-height: 45vh; }
        }
    </style>
</head>
<body>

<header>
    <h1>GHOST LINE</h1>
    <div class="subtitle">OpenClaw Adventures — Game #012</div>
</header>

<div id="scene-name">STATION PLATFORM</div>

<div class="game-container">
    <!-- Art panel: 640x400 SVG art, scales to fill panel -->
    <div class="art-panel">
        <div id="art-display">
            <span class="no-art">[ART LOADING]</span>
        </div>
    </div>

    <!-- Text panel: narrative, commands, inventory, exits -->
    <div class="text-panel">
        <div id="text-display"></div>

        <div class="command-bar">
            <button class="cmd-btn" data-cmd="look">LOOK</button>
            <button class="cmd-btn" data-cmd="take">TAKE</button>
            <button class="cmd-btn" data-cmd="use">USE</button>
            <button class="cmd-btn" data-cmd="examine">EXAMINE</button>
            <button id="hint-toggle" class="cmd-btn">HINTS: ON</button>
        </div>

        <div class="inventory-panel">
            <h3>INVENTORY</h3>
            <div id="inventory-bar">
                <span id="inv-empty">(empty)</span>
            </div>
        </div>

        <div class="exits-panel">
            <h3>EXITS</h3>
            <div id="exits-bar"></div>
        </div>
    </div>
</div>

<footer>
    OpenClaw Point &amp; Click Studio | LOOK · TAKE · USE · EXAMINE | Click exits to move | /restart to reset
</footer>

<script>
// ============================================================
// GAME DATA — replace with assembled content from game-script.json
// ============================================================
var GAME_DATA = {"title": "Ghost Line", "slug": "subway-ghost-train", "number": 12, "setting": "An abandoned underground subway station where a phantom train still runs on its cursed schedule. The spirits of commuters from a flood disaster forever ride the rails.", "characters": [{"id": "conductor-ghost", "name": "The Conductor", "description": "A spectral figure in a tattered uniform who never stops calling destinations that don't exist."}, {"id": "whisperer", "name": "The Whisperer", "description": "A presence that speaks through the tunnel winds, revealing fragments of the disaster."}], "items": [{"id": "turnstile-key", "name": "Turnstile Key", "description": "A heavy iron key that operates the fare gates.", "foundIn": "station-platform", "usedIn": "station-platform", "usedOn": "locked-turnstile"}, {"id": "lantern", "name": "Lantern", "description": "A battery-powered lantern with a dim but serviceable bulb.", "foundIn": "maintenance-room", "usedIn": "tunnel-north", "usedOn": "collapsed-debris"}, {"id": "maintenance-log", "name": "Maintenance Log", "description": "A water-stained logbook detailing the day of the flood and the train that never returned.", "foundIn": "maintenance-room", "usedIn": "signal-room", "usedOn": "signal-console"}, {"id": "circuit-breaker", "name": "Circuit Breaker", "description": "A replacement breaker for the platform lighting circuit.", "foundIn": "signal-room", "usedIn": "station-platform", "usedOn": "lighting-panel"}, {"id": "brake-handle", "name": "Brake Handle", "description": "The manual release for the ghost train's emergency brake system.", "foundIn": "signal-room", "usedIn": "ghost-train", "usedOn": "brake-mechanism"}], "scenes": [{"id": "station-platform", "name": "Station Platform", "prose": "A cracked and grimy platform stretches into darkness. Flickering\u8367\u5149 signs read 'NO SERVICE'. A turnstile blocks the way onto the platform. Tracks gleam with wetness. Down the tunnel, a faint light pulses.", "exits": {"east": "maintenance-room", "south": "tunnel-north"}, "items": ["turnstile-key"], "puzzles": ["locked-turnstile"], "lookDescriptions": {"turnstile": "A heavy fare gate, locked. You need a key.", "tracks": "The rails are wet and cold. Something heavy recently passed."}}, {"id": "maintenance-room", "name": "Maintenance Room", "prose": "A cramped room filled with tool racks and spare parts. A faded MTA map covers one wall. There's a lantern on a workbench and a logbook soaked with water stains. The door to the signal room is rusty but unlocked.", "exits": {"west": "station-platform", "south": "signal-room"}, "items": ["lantern", "maintenance-log"], "puzzles": [], "lookDescriptions": {"workbench": "Various tools lie scattered. The lantern still works.", "logbook": "Entries describe a flood that trapped a train underground."}}, {"id": "signal-room", "name": "Signal Room", "prose": "Racks of relays and wires fill this room. A signal console glows faintly. A breaker panel hangs open, one slot empty. A heavy brake handle labeled 'GHOST TRAIN' rests on a shelf. The room connects back to the maintenance room and the platform.", "exits": {"north": "maintenance-room", "east": "station-platform"}, "items": ["circuit-breaker", "brake-handle"], "puzzles": ["signal-console", "platform-lights"], "lookDescriptions": {"signal console": "It displays a track map. One line is highlighted: 'Train 7 - Delayed'.", "breaker panel": "Missing a 20-amp breaker. Without it, the platform lights are out."}}, {"id": "tunnel-north", "name": "North Tunnel", "prose": "The tunnel is narrow, walls slick with condensation. Debris blocks the path forward. A faint breeze carries whispers. Your lantern barely cuts through the darkness. The platform is back north.", "exits": {"north": "station-platform"}, "items": [], "puzzles": ["clear-debris"], "lookDescriptions": {"debris": "A collapsed section of ceiling. You could cut through with something.", "whispers": "Voices saying '...next stop... never...'"}}, {"id": "ghost-train", "name": "Ghost Train", "prose": "The train car is transparent, like a hologram. Inside, ghostly commuters sit motionless. The emergency brake system is visible. The train lurches forward as you board. You must release the brake to escape.", "exits": {}, "items": [], "puzzles": ["release-brake"], "lookDescriptions": {"brake mechanism": "A large wheel with a release lever. It needs a manual handle.", "passengers": "Their eyes follow you, pleading."}}, {"id": "escape-platform", "name": "Escape Platform", "prose": "You've cleared the debris, restored power, and boarded the ghost train. By releasing the brake, the train speeds through the phantom tunnels and emerges at an abandoned interchange that leads to the surface. The spirits are at peace. You escape.", "exits": {}, "items": [], "puzzles": [], "lookDescriptions": {"interchange": "A ghostly platform bathed in moonlight. The way out is clear."}}], "puzzles": [{"id": "locked-turnstile", "scene": "station-platform", "requires": ["turnstile-key"], "action": "use turnstile-key on fare gate", "result": "The turnstile clicks and swings open. You can now access the platform area.", "reveals": [], "blocksExit": {"scene": "station-platform", "direction": "south"}, "blockedMessage": "The fare gate is locked. Find a key to proceed."}, {"id": "clear-debris", "scene": "tunnel-north", "requires": ["lantern"], "action": "use lantern to illuminate debris and cut through", "result": "With light, you spot a weak point in the rubble. After effort, the path is clear. You see a ghost train ahead.", "reveals": ["ghost-train"], "blocksExit": {"scene": "tunnel-north", "direction": "south"}, "blockedMessage": "The tunnel is blocked by collapsed rubble. You need a tool to clear it."}, {"id": "signal-console", "scene": "signal-room", "requires": ["maintenance-log"], "action": "use maintenance-log on signal console", "result": "The logbook contains the override codes. The console accepts them and displays: 'TRAIN 7 CLEARED FOR DEPARTURE'. The ghost train becomes accessible.", "reveals": ["ghost-train"], "blocksExit": {}, "blockedMessage": ""}, {"id": "platform-lights", "scene": "signal-room", "requires": ["circuit-breaker"], "action": "install circuit-breaker in panel", "result": "The platform lights flicker on, illuminating the tracks and the train's arrival.", "reveals": [], "blocksExit": {}, "blockedMessage": ""}, {"id": "release-brake", "scene": "ghost-train", "requires": ["brake-handle"], "action": "use brake-handle on emergency mechanism", "result": "You pull the lever. The brake releases. The train accelerates, cycling through tunnels and emerging at an escape platform. YOU WIN.", "reveals": ["escape-platform"], "blocksExit": {}, "blockedMessage": ""}], "winCondition": {"scene": "escape-platform", "requires": [], "description": "You have escaped the subway, freeing both yourself and the commuter ghosts. The phantom train fades into the dawn."}};var GAME_ART={"scene-station-platform": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- platform -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#2a2a3a\"/>\n  <!-- tracks -->\n  <g fill=\"#1a1a2a\">\n    <rect x=\"100\" y=\"270\" width=\"440\" height=\"10\"/>\n    <rect x=\"100\" y=\"300\" width=\"440\" height=\"10\"/>\n  </g>\n  <!-- turnstile -->\n  <g transform=\"translate(50,200)\">\n    <rect x=\"0\" y=\"0\" width=\"60\" height=\"80\" fill=\"#3a3a4a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <rect x=\"10\" y=\"20\" width=\"40\" height=\"40\" fill=\"#0f0\"/>\n  </g>\n  <!-- tunnel entrance south -->\n  <rect x=\"300\" y=\"150\" width=\"120\" height=\"100\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"360\" y=\"195\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">TUNNEL</text>\n  <!-- flickering sign -->\n  <g transform=\"translate(500,80)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"30\" fill=\"#000\" stroke=\"#f00\" stroke-width=\"2\"/>\n    <text x=\"40\" y=\"18\" font-family=\"monospace\" font-size=\"8\" fill=\"#f00\" text-anchor=\"middle\">NO SERVICE</text>\n  </g>\n</svg>", "scene-maintenance-room": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"250\" fill=\"#1a1a2a\"/>\n  <!-- floor -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- tool racks -->\n  <g fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\">\n    <rect x=\"50\" y=\"150\" width=\"120\" height=\"80\"/>\n    <rect x=\"200\" y=\"150\" width=\"120\" height=\"80\"/>\n  </g>\n  <!-- workbench with lantern -->\n  <rect x=\"400\" y=\"180\" width=\"150\" height=\"50\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n  <!-- lantern on bench -->\n  <g transform=\"translate(420,190)\">\n    <rect x=\"0\" y=\"0\" width=\"20\" height=\"30\" fill=\"#4a4a5a\" stroke=\"#0f0\" stroke-width=\"1\"/>\n    <circle cx=\"10\" cy=\"10\" r=\"8\" fill=\"#0f0\"/>\n  </g>\n  <!-- logbook on bench -->\n  <g transform=\"translate(480,200)\">\n    <rect x=\"0\" y=\"0\" width=\"40\" height=\"30\" fill=\"#5a3a1a\" stroke=\"#ffd700\" stroke-width=\"1\"/>\n  </g>\n  <!-- exit west to platform -->\n  <rect x=\"100\" y=\"320\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"140\" y=\"352\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n  <!-- exit south to signal -->\n  <rect x=\"300\" y=\"340\" width=\"80\" height=\"40\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"340\" y=\"372\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">SIGNAL</text>\n</svg>", "scene-signal-room": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"250\" fill=\"#1a1a2a\"/>\n  <!-- floor -->\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- relay racks -->\n  <g fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\">\n    <rect x=\"50\" y=\"100\" width=\"150\" height=\"120\"/>\n    <rect x=\"450\" y=\"100\" width=\"150\" height=\"120\"/>\n  </g>\n  <!-- signal console -->\n  <g transform=\"translate(260,120)\">\n    <rect x=\"0\" y=\"0\" width=\"120\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <rect x=\"10\" y=\"20\" width=\"100\" height=\"20\" fill=\"#0f0\"/>\n    <text x=\"60\" y=\"32\" font-family=\"monospace\" font-size=\"8\" fill=\"#000\" text-anchor=\"middle\">TRAIN 7</text>\n  </g>\n  <!-- breaker panel -->\n  <g transform=\"translate(500,250)\">\n    <rect x=\"0\" y=\"0\" width=\"80\" height=\"50\" fill=\"#2a2a3a\" stroke=\"#f00\" stroke-width=\"2\"/>\n    <rect x=\"10\" y=\"15\" width=\"20\" height=\"20\" fill=\"#f00\"/>\n    <text x=\"40\" y=\"28\" font-family=\"monospace\" font-size=\"8\" fill=\"#f00\" text-anchor=\"middle\">EMPTY</text>\n  </g>\n  <!-- brake handle on shelf -->\n  <g transform=\"translate(100,200)\">\n    <rect x=\"0\" y=\"0\" width=\"60\" height=\"30\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n    <circle cx=\"30\" cy=\"15\" r=\"8\" fill=\"#ff4500\"/>\n  </g>\n  <!-- exits -->\n  <rect x=\"200\" y=\"330\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"240\" y=\"362\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n  <rect x=\"300\" y=\"80\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"340\" y=\"112\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">MAINT</text>\n</svg>", "scene-tunnel-north": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- tunnel walls -->\n  <rect x=\"0\" y=\"0\" width=\"640\" height=\"150\" fill=\"#1a1a2a\"/>\n  <rect x=\"0\" y=\"250\" width=\"640\" height=\"150\" fill=\"#0d0d1a\"/>\n  <!-- arched ceiling -->\n  <path d=\"M0,150 Q320,100 640,150\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <!-- debris pile -->\n  <g transform=\"translate(300,200)\">\n    <rect x=\"0\" y=\"0\" width=\"100\" height=\"60\" fill=\"#3a3a4a\" stroke=\"#0f0\" stroke-width=\"2\"/>\n    <polygon points=\"20,0 80,0 50,-20\" fill=\"#2a2a3a\"/>\n  </g>\n  <!-- light from ghost train ahead -->\n  <circle cx=\"320\" cy=\"180\" r=\"20\" fill=\"#fff\" opacity=\"0.5\"/>\n  <!-- whispers -->\n  <g font-family=\"monospace\" font-size=\"8\" fill=\"#aaa\">\n    <text x=\"100\" y=\"120\">...next stop...</text>\n    <text x=\"400\" y=\"140\">...never...</text>\n  </g>\n  <!-- exit north to platform -->\n  <rect x=\"280\" y=\"30\" width=\"80\" height=\"60\" fill=\"#1a1a2a\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <text x=\"320\" y=\"62\" font-family=\"monospace\" font-size=\"10\" fill=\"#0f0\" text-anchor=\"middle\">PLAT</text>\n</svg>", "scene-ghost-train": "<svg xmlns=\"http://www.w3.org/2000/svg\" viewBox=\"0 0 640 400\">\n  <rect width=\"640\" height=\"400\" fill=\"#0a0a1a\"/>\n  <!-- train car outline -->\n  <ellipse cx=\"320\" cy=\"200\" rx=\"200\" ry=\"80\" fill=\"none\" stroke=\"#0f0\" stroke-width=\"4\"/>\n  <!-- ghostly passengers -->\n  <g fill=\"#666\" opacity=\"0.6\">\n    <ellipse cx=\"260\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n    <ellipse cx=\"320\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n    <ellipse cx=\"380\" cy=\"180\" rx=\"15\" ry=\"30\"/>\n  </g>\n  <!-- emergency brake mechanism -->\n  <g transform=\"translate(280,250)\">\n    <circle cx=\"20\" cy=\"20\" r=\"30\" fill=\"#2a2a3a\" stroke=\"#0f0\" stroke-width=\"3\"/>\n    <line x1=\"20\" y1=\"20\" x2=\"20\" y2=\"50\" stroke=\"#888\" stroke-width=\"4\"/>\n    <circle cx=\"20\" cy=\"20\" r=